rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fields an owner may never change on their own member doc.
    function memberProtectedUnchanged() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.team == resource.data.team
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /members/{uid} {
      allow read: if resource.data.isPublic == true || isOwner(uid) || isAdmin();
      allow create: if isAdmin() || (isOwner(uid) && request.resource.data.id == uid);
      allow update: if isAdmin()
        || (isOwner(uid) && memberProtectedUnchanged());
      allow delete: if isAdmin();
    }

    // Username reservation docs: usernames/{username} -> { uid }.
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      // Clients create their own registration; server routes verify fields and
      // sign the ticket. Attendance/check-in transitions are admin only.
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.status == 'registered';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projectSlugs/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /roadmap_items/{itemId} {
      allow read: if true;
      // voteCount is denormalized and only mutated via server transactions/admin.
      allow write: if isAdmin();
    }

    match /roadmap_votes/{voteId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && voteId == request.resource.data.itemId + '_' + request.auth.uid;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
      allow update: if false;
    }

    match /admin_users/{uid} {
      allow read: if isAdmin();
      allow write: if false; // seed script / console only
    }

    // Deny everything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
