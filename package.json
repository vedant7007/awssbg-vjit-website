{
  "name": "awssbg-vjit-website",
  "version": "0.1.0",
  "private": true,
  "description": "Official website of AWS Student Builder Group at VJIT",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "typecheck": "tsc --noEmit",
