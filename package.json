    "firebase-admin": "^12.7.0",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.5",
    "html5-qrcode": "^2.3.8",
    "lenis": "^1.1.18",
    "lucide-react": "^0.460.0",
    "meshline": "3.3.1",
    "next": "15.5.20",
    "next-themes": "^0.4.4",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "resend": "^4.0.1",
    "server-only": "^0.0.1",
